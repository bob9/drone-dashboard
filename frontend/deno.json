{
	"tasks": {
		"dev": "deno run -A --node-modules-dir npm:vite",
		"build": "deno run -A --node-modules-dir npm:vite build --emptyOutDir",
		"preview": "deno run -A --node-modules-dir npm:vite preview",
		"serve": "deno run --allow-net --allow-read jsr:@std/http@1/file-server dist/",
		"test": "deno test --allow-env --allow-read --allow-net --allow-write --unstable-broadcast-channel --parallel",
		"test:watch": "deno test --allow-env --allow-read --allow-net --allow-write --unstable-broadcast-channel --watch --parallel",
		"verify": "deno fmt && deno lint --fix && deno check -q"
	},
	"test": {
		"include": [
			"src/**/*.test.ts",
			"src/**/*.test.tsx"
		]
	},
	"compilerOptions": {
		"lib": [
			"ES2020",
			"DOM",
			"DOM.Iterable"
		],
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"jsxImportSourceTypes": "@types/react",
		"types": [
			"@types/react",
			"vite/client"
		]
	},
	"imports": {
		"@b-fuze/deno-dom": "jsr:@b-fuze/deno-dom@^0.1.49",
		"@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.6",
		"@react-spring/web": "npm:@react-spring/web@^10.0.1",
		"@tanstack/query-core": "npm:@tanstack/query-core@^5.75.0",
		"@tanstack/react-router": "npm:@tanstack/react-router@^1.131.35",
		"@tanstack/react-router-devtools": "npm:@tanstack/react-router-devtools@^1.131.35",
		"@tanstack/router-plugin": "npm:@tanstack/router-plugin@^1.131.35",
		"@testing-library/react": "npm:@testing-library/react@^16.3.0",
		"@types/react": "npm:@types/react@^19.1.2",
		"@types/react-dom": "npm:@types/react-dom@^19.1.3",
		"@vitejs/plugin-react-swc": "npm:@vitejs/plugin-react-swc@^3.9.0",
		"axios": "npm:axios@^1.9.0",
		"echarts": "npm:echarts@^6.0.0",
		"fast-deep-equal": "npm:fast-deep-equal@^3.1.3",
		"global-jsdom": "npm:global-jsdom@^26.0.0",
		"jotai": "npm:jotai@^2.12.3",
		"jotai-eager": "npm:jotai-eager@^0.2.3",
		"jotai-tanstack-query": "npm:jotai-tanstack-query@^0.9.0",
		"jsdom": "npm:jsdom@^26.1.0",
		"msw": "npm:msw@^2.7.5",
		"pocketbase": "npm:pocketbase@^0.26.2",
		"qrcode.react": "npm:qrcode.react@^4.2.0",
		"react": "npm:react@^19.1.0",
		"react-dom": "npm:react-dom@^19.1.0",
		"vite": "npm:vite@^6.3.4",
		"@std/assert": "jsr:@std/assert@1.0.13",
		"@std/testing": "jsr:@std/testing@1.0.11",
		"zod": "npm:zod@^3.25.7"
	},
	"lint": {
		"rules": {
			"tags": [
				"recommended"
			],
			"include": [
				"ban-untagged-todo"
			],
			"exclude": [
				"no-unused-vars"
			]
		}
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 140,
		"singleQuote": true
	}
}
